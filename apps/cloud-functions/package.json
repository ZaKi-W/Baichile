{
  "name": "@baichile/cloud-functions",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare:deploy": "pnpm run build && node scripts/prepare-deploy-package.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed:catalog": "ts-node scripts/seed-catalog.ts",
    "backfill:catalog-search": "ts-node scripts/backfill-catalog-search.ts",
    "import:cloudbase": "ts-node scripts/import-cloudbase.ts",
    "verify:cloudbase": "ts-node scripts/verify-cloudbase.ts",
    "migrate:catalog-images": "ts-node scripts/migrate-catalog-images.ts"
  },
  "dependencies": {
    "@baichile/api-contract": "workspace:*",
    "@baichile/catalog-data": "workspace:*",
    "@baichile/domain": "workspace:*",
    "@baichile/map-core": "workspace:*",
    "@cloudbase/node-sdk": "^3.18.3",
    "wx-server-sdk": "^4.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
