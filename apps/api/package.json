{
  "name": "@baichile/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "db:migrate": "typeorm-ts-node-commonjs -d src/database/typeorm.data-source.ts migration:run",
    "db:revert": "typeorm-ts-node-commonjs -d src/database/typeorm.data-source.ts migration:revert",
    "db:seed": "ts-node src/database/seed.ts",
    "db:import-chownow": "ts-node src/scripts/import-chownow-catalog.ts",
    "db:import-catalog": "ts-node src/scripts/import-chownow-catalog.ts",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. apps/api/test --no-file-parallelism"
  },
  "dependencies": {
    "@baichile/api-contract": "workspace:*",
    "@baichile/domain": "workspace:*",
    "@baichile/map-core": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/typeorm": "^11.0.0",
    "dotenv": "^17.2.0",
    "fastify": "5.8.5",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.25",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.0",
    "@types/node": "^22.15.0",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
