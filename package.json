{
  "name": "baichile",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:h5": "pnpm --filter @baichile/client build:h5",
    "build:mp-weixin": "pnpm --filter @baichile/client build:mp-weixin",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @baichile/api db:migrate",
    "db:seed": "pnpm --filter @baichile/api db:seed",
    "db:import-catalog": "pnpm --filter @baichile/api db:import-catalog",
    "db:up": "docker compose up -d postgres",
    "dev": "pnpm --parallel --filter @baichile/api --filter @baichile/client dev",
    "dev:admin": "pnpm --filter @baichile/admin dev",
    "dev:api": "pnpm --filter @baichile/api dev",
    "dev:h5": "pnpm --filter @baichile/client dev:h5",
    "dev:mp-weixin": "pnpm --filter @baichile/client dev:mp-weixin",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
