{
  "name": "baichile",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:h5": "pnpm --filter @baichile/client build:h5",
    "build:mp-weixin": "pnpm --filter @baichile/client build:mp-weixin",
    "catalog:refresh:choutuan": "pnpm --filter @baichile/catalog-data refresh:choutuan",
    "cloudbase:build": "pnpm --filter @baichile/cloud-functions build",
    "cloudbase:prepare-deploy": "pnpm --filter @baichile/cloud-functions prepare:deploy",
    "cloudbase:seed": "pnpm --filter @baichile/cloud-functions seed:catalog",
    "cloudbase:import": "pnpm --filter @baichile/cloud-functions import:cloudbase",
    "cloudbase:verify": "pnpm --filter @baichile/cloud-functions verify:cloudbase",
    "catalog-images:migrate": "pnpm --filter @baichile/cloud-functions migrate:catalog-images",
    "dev": "pnpm --filter @baichile/client dev:mp-weixin",
    "dev:admin": "pnpm --filter @baichile/admin dev",
    "dev:h5": "pnpm --filter @baichile/client dev:h5",
    "dev:mp-weixin": "pnpm --filter @baichile/client dev:mp-weixin",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
